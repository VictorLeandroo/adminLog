generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  DRIVER
  FINANCE
}

enum VehicleStatus {
  OK
  ATTENTION
  MAINTENANCE
}

enum RouteStatus {
  IN_PROGRESS
  PENDING_REVIEW
  COMPLETED
}

enum DocumentType {
  CRLV
  INSURANCE
  INVOICE
  OTHER
}

enum StatementStatus {
  REQUESTED
  PROCESSING
  DONE
  CANCELED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(DRIVER)
  active       Boolean  @default(true)
  photoUrl     String?
  photoName    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedVehicles Vehicle[] @relation("VehicleDriver")
  routes           Route[]   @relation("RouteDriver")
  expenses         Expense[] @relation("ExpenseCreator")
  salaryExpenses   Expense[] @relation("ExpenseDriver")
  revenues         Revenue[] @relation("RevenueCreator")
}

model Vehicle {
  id                  String        @id @default(uuid())
  model               String
  year                Int?
  plate               String        @unique
  currentKm           Int           @default(0)
  nextMaintenanceAtKm Int?
  renavam             String?
  chassis             String?
  photoUrl            String?
  photoName           String?
  licenseValidUntil   DateTime?
  insuranceValidUntil DateTime?
  status              VehicleStatus @default(OK)
  driverId            String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  driver       User?                @relation("VehicleDriver", fields: [driverId], references: [id])
  documents    VehicleDocument[]
  maintenances VehicleMaintenance[]
  routes       Route[]
  expenses     Expense[]
}

model VehicleDocument {
  id        String       @id @default(uuid())
  vehicleId String
  name      String
  type      DocumentType @default(OTHER)
  fileUrl   String
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model VehicleMaintenance {
  id          String   @id @default(uuid())
  vehicleId   String
  type        String
  date        DateTime
  km          Int
  workshop    String?
  amount      Decimal? @db.Decimal(12, 2)
  nextDueKm   Int?
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model Route {
  id                  String      @id @default(uuid())
  vehicleId           String
  driverId            String
  date                DateTime
  initialKm           Int
  finalKm             Int?
  plannedDeliveries   Int?
  freightAmount       Decimal?    @db.Decimal(12, 2)
  status              RouteStatus @default(IN_PROGRESS)
  correctionRequested Boolean     @default(false)
  correctionNote      String?
  startedAt           DateTime    @default(now())
  finishedAt          DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  vehicle  Vehicle      @relation(fields: [vehicleId], references: [id])
  driver   User         @relation("RouteDriver", fields: [driverId], references: [id])
  cities   RouteCity[]
  invoices RouteInvoice[]
  photos   RoutePhoto[]
}

model RouteCity {
  id      String @id @default(uuid())
  routeId String
  name    String

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

model RouteInvoice {
  id      String @id @default(uuid())
  routeId String
  number  String

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

model RoutePhoto {
  id            String    @id @default(uuid())
  routeId       String
  fileUrl       String
  fileName      String?
  deliveryIndex Int?
  deliveryNote  String?
  deliveredAt   DateTime?
  createdAt     DateTime  @default(now())

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)
}

model FreightSetting {
  id                String   @id @default("default")
  baseAmount        Decimal  @default(400) @db.Decimal(12, 2)
  includedKm        Int      @default(120)
  excessKmAmount    Decimal  @default(1.5) @db.Decimal(12, 2)
  updatedAt         DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  vehicleId   String?
  createdById String
  driverId    String?
  date        DateTime
  category    String
  description String?
  amount      Decimal  @db.Decimal(12, 2)
  paid        Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle   Vehicle?       @relation(fields: [vehicleId], references: [id])
  createdBy User           @relation("ExpenseCreator", fields: [createdById], references: [id])
  driver    User?          @relation("ExpenseDriver", fields: [driverId], references: [id])
  photos    ExpensePhoto[]
}

model ExpensePhoto {
  id        String   @id @default(uuid())
  expenseId String
  fileUrl   String
  fileName  String?
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

model Revenue {
  id          String   @id @default(uuid())
  createdById String
  date        DateTime
  description String
  company     String?
  amount      Decimal  @db.Decimal(12, 2)
  paid        Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User @relation("RevenueCreator", fields: [createdById], references: [id])
}

model FreightStatementRequest {
  id        String          @id @default(uuid())
  startDate DateTime
  endDate   DateTime
  company   String
  note      String?
  status    StatementStatus @default(REQUESTED)
  fileUrl   String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}
